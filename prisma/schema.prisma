generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  IN_PERSON_DEPOSIT
  CARD_LINK
  BANK_TRANSFER
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PROOF_SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentProofStatus {
  PENDING
  VALID
  INVALID
}

model Client {
  id              String         @id @default(cuid())
  whatsappNumber  String         @unique
  name            String?
  lastName        String?
  formalId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations   Conversation[]
  bookings        Booking[]
  messages        Message[]
}

model Conversation {
  id              String      @id @default(cuid())
  clientId        String
  currentIntent   String      @default("unknown")
  currentStep     String      @default("idle")
  collectedData   Json?
  lastBookingId   String?
  botPaused       Boolean     @default(false) @map("bot_paused")
  takenOverByAgent Boolean    @default(false) @map("taken_over_by_agent")
  takenOverAt     DateTime?   @map("taken_over_at")
  takenOverByUserId String?   @map("taken_over_by_user_id")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lastBooking     Booking?    @relation("LastBooking", fields: [lastBookingId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  messages        Message[]
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  clientId        String
  direction       String
  messageType     String
  content         String
  providerId      String?
  mediaUrl        String?       @map("media_url")
  metadata        Json?
  createdAt       DateTime      @default(now())
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Service {
  id                String      @id @default(cuid())
  code              String      @unique
  name              String
  description       String
  durationMinutes   Int
  price             Int
  currency          String      @default("CLP")
  calendarId        String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  bookings          Booking[]
  specialistLinks   SpecialistService[]
}

model Booking {
  id                  String          @id @default(cuid())
  clientId            String
  serviceId           String
  specialistId        String?
  status              BookingStatus   @default(PENDING)
  paymentMethod       PaymentMethod?
  paymentStatus       PaymentStatus   @default(PENDING)
  paymentProofStatus  PaymentProofStatus @default(PENDING)
  payerName           String?
  payerLastName       String?
  payerFormalId       String?
  payerEmail          String?
  scheduledAt         DateTime
  endAt               DateTime
  holdExpiresAt       DateTime?
  notes               String?
  depositAmount       Int             @default(100)
  calendarEventId     String?
  reminderSentAt      DateTime?
  paymentProofReceivedAt DateTime?
  paymentProofMetadata   Json?
  paymentProofValidation Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  client              Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service             Service         @relation(fields: [serviceId], references: [id])
  specialist          Specialist?     @relation(fields: [specialistId], references: [id], onDelete: SetNull)
  paymentLink         PaymentLink?
  conversations       Conversation[]  @relation("LastBooking")
}

model Specialist {
  id              String              @id
  userId          BigInt?
  name            String
  specialty       String?
  active          Boolean             @default(true)
  workSchedule    String?
  bookings        Booking[]
  serviceLinks    SpecialistService[]
  availabilities  Availability[]
}

model Availability {
  id            String      @id
  specialistId  String
  dayOfWeek     Int
  startTime     DateTime    @db.Time(0)
  endTime       DateTime    @db.Time(0)
  specialist    Specialist  @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model SpecialistService {
  serviceId     String     @map("A")
  specialistId  String     @map("B")
  service       Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  specialist    Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@id([serviceId, specialistId])
  @@map("_SpecialistServices")
}

model PaymentLink {
  id              String      @id @default(cuid())
  bookingId       String      @unique
  provider        String
  url             String
  amount          Int
  currency        String      @default("CLP")
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  booking         Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
